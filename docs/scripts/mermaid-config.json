{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif",
    "fontSize": "15px",
    "primaryColor": "#ffffff",
    "primaryTextColor": "#0f172a",
    "primaryBorderColor": "#0d9488",
    "secondaryColor": "#ffffff",
    "secondaryTextColor": "#0f172a",
    "secondaryBorderColor": "#64748b",
    "tertiaryColor": "#f1f5f9",
    "tertiaryTextColor": "#0f172a",
    "tertiaryBorderColor": "#475569",
    "lineColor": "#334155",
    "textColor": "#0f172a",
    "mainBkg": "#ffffff",
    "nodeBorder": "#475569",
    "clusterBkg": "#e8eef4",
    "clusterBorder": "#64748b",
    "edgeLabelBackground": "#ffffff",
    "titleColor": "#0f172a",
    "actorBkg": "#e8eef4",
    "actorBorder": "#0d9488",
    "actorTextColor": "#0f172a",
    "actorLineColor": "#0d9488",
    "signalColor": "#334155",
    "signalTextColor": "#0f172a",
    "labelBoxBkgColor": "#e8eef4",
    "labelBoxBorderColor": "#0d9488",
    "labelTextColor": "#0f172a",
    "loopTextColor": "#0f172a",
    "activationBkgColor": "#f1f5f9",
    "activationBorderColor": "#475569",
    "noteBkgColor": "#fef3c7",
    "noteTextColor": "#78350f",
    "noteBorderColor": "#ca8a04"
  },
  "flowchart": {
    "curve": "basis",
    "padding": 18,
    "nodeSpacing": 52,
    "rankSpacing": 60,
    "diagramPadding": 14,
    "htmlLabels": true,
    "useMaxWidth": true
  },
  "sequence": {
    "actorFontSize": 15,
    "messageFontSize": 14,
    "noteFontSize": 12,
    "mirrorActors": false,
    "boxMargin": 10,
    "boxTextMargin": 6
  }
}
