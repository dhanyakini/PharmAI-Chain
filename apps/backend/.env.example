APP_NAME=sentinel-backend
ENV=local
DEBUG=true
SECRET_KEY=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sentinel
REDIS_URL=redis://localhost:6379/0

GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional: OpenWeather Current Weather API (real ambient temp at truck lat/lng).
# If unset, simulation uses a deterministic local fallback.
# OPENWEATHER_API_KEY=
# WEATHER_CACHE_TTL_SECONDS=300

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WS_ORIGIN=http://localhost:5173

SIMULATION_TICK_SECONDS=5
SIMULATED_MINUTES_PER_TICK=15
# Trigger agent workflow when internal temp (°F) falls to or below this (insulin cold-chain risk)
TEMPERATURE_THRESHOLD_F=36.0
# Physical band for cargo (°F) — proposal: 35–77°F storage
TARGET_TEMP_LOW_F=35.0
TARGET_TEMP_HIGH_F=77.0

# Thermal model: internal temp relaxes toward ambient with time constant (hours^-1 scale)
THERMAL_COUPPLING_PER_HOUR=0.35
# HVAC pulls internal toward setpoint (middle of band)
HVAC_SETPOINT_F=56.0
HVAC_STRENGTH_PER_HOUR=0.25

# Supervisor multi-objective weights (must sum to 1.0)
SUPERVISOR_WEIGHT_SAFETY=0.5
SUPERVISOR_WEIGHT_TIME=0.3
SUPERVISOR_WEIGHT_COST=0.2

LOG_LEVEL=INFO
